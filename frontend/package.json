    "compression": "^1.7.5",
    "express": "^5.2.1",
    "http-proxy-middleware": "^3.0.5",
    "isbot": "^5.1.40",
    "mime-types": "^3.0.2",
    "morgan": "^1.10.0",
    "react": "^19.2.5",
    "react-bootstrap": "^2.10.10",
    "react-dom": "^19.2.5",
    "react-dropzone": "^15.0.0",
    "react-router": "^7.5.3",
    "remix-auth": "^4.2.0",
    "remix-auth-form": "^3.0.0",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@react-router/dev": "^7.5.3",
